}
body.theme-light .add-content,
body.theme-light .move-content {
background:rgba(248,250,252,0.98);
border-color:rgba(148,163,184,0.8);
box-shadow:0 20px 60px rgba(148,163,184,0.8);
}
.add-content h3,
.move-content h3 {
