}
body.theme-light .add-content h3,
body.theme-light .move-content h3 {
color:#4f46e5;
}
.swap-menu {
position:absolute;
top:100%;
left:50%;
transform:translateX(-50%);
margin-top:6px;
background:rgba(15,23,42,0.98);
border-radius:14px;
border:1px solid rgba(148,163,184,0.7);
box-shadow:0 18px 50px rgba(0,0,0,0.9);
padding:6px;
display:none;
z-index:2500;
min-width:220px;
