
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Staffing Automatique v9.3 - Liquid Glass</title>
<style>
:root {
--bg-main-dark: radial-gradient(circle at top, #020617 0, #020617 40%, #000 100%);
--bg-main-light: radial-gradient(circle at top, #e5e7eb 0, #f9fafb 40%, #e5e7eb 100%);
--card-dark: rgba(15,23,42,0.96);
--card-light: rgba(248,250,252,0.9);
--border-dark: rgba(148,163,184,0.55);
--border-light: rgba(148,163,184,0.45);
--text-main-dark: #e5e7eb;
--text-main-light: #111827;
--text-muted-dark: #9ca3af;
--text-muted-light: #6b7280;
--accent-blue: #38bdf8;
--accent-indigo: #6366f1;
--accent-green: #22c55e;
--accent-amber: #facc15;
--accent-rose: #fb7185;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
font-family: system-ui, -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", sans-serif;
background: var(--bg-main-dark);
color: var(--text-main-dark);
padding: 18px;
min-height: 100vh;
font-size: 14px;
transition: background 0.4s ease, color 0.4s ease;
}
body.theme-light {
background: var(--bg-main-light);
color: var(--text-main-light);
}
.container {
max-width: 1600px;
margin: 0 auto;
background: radial-gradient(circle at top, rgba(15,23,42,0.96), rgba(15,23,42,0.92));
border-radius: 24px;
box-shadow: 0 24px 80px rgba(0,0,0,0.75);
overflow: hidden;
border: 1px solid var(--border-dark);
backdrop-filter: blur(22px);
transition: background 0.4s ease, border-color 0.4s ease;
}
body.theme-light .container {
background: radial-gradient(circle at top, rgba(248,250,252,0.96), rgba(241,245,249,0.96));
border-color: var(--border-light);
}
.header {
background: linear-gradient(135deg, rgba(56,189,248,0.18), rgba(129,140,248,0.22));
color: #f9fafb;
padding: 18px 22px;
border-bottom: 1px solid rgba(148,163,184,0.35);
position: relative;
overflow: hidden;
}
.header::before {
content:"";
position:absolute;
inset:-40%;
background:
radial-gradient(circle at top left, rgba(96,165,250,0.35), transparent 55%),
radial-gradient(circle at bottom right, rgba(129,140,248,0.25), transparent 55%);
opacity:0.7;
pointer-events:none;
}
.header-main {
display:flex;
justify-content:space-between;
align-items:center;
position:relative;
z-index:1;
}
.header-title-block h1 {
font-size: 1.6em;
margin-bottom: 4px;
letter-spacing: .06em;
}
.header-title-block p {
font-size: 0.9em;
opacity: 0.9;
}
.header-actions {
display:flex;
align-items:center;
gap:10px;
}
.nav-btn {
background: rgba(15,23,42,0.85);
color:#e5e7eb;
border-radius:999px;
border:1px solid rgba(148,163,184,0.7);
padding:7px 14px;
font-size:0.8em;
font-weight:500;
display:flex;
align-items:center;
gap:6px;
cursor:pointer;
backdrop-filter: blur(18px);
box-shadow:0 10px 25px rgba(15,23,42,0.9);
transition:all 0.2s;
}
.nav-btn:hover {
transform:translateY(-1px);
box-shadow:0 14px 35px rgba(15,23,42,0.95);
}
.theme-toggle {
width:40px;
height:22px;
border-radius:999px;
border:1px solid rgba(148,163,184,0.8);
background:rgba(15,23,42,0.9);
display:flex;
align-items:center;
padding:2px;
cursor:pointer;
position:relative;
}
.theme-toggle-thumb {
width:18px;
height:18px;
border-radius:999px;
background:linear-gradient(135deg,#facc15,#f97316);
box-shadow:0 4px 10px rgba(0,0,0,0.4);
transform:translateX(0);
transition:transform 0.25s ease, background 0.25s ease;
}
body.theme-light .theme-toggle {
background:rgba(248,250,252,0.9);
}
body.theme-light .theme-toggle-thumb {
transform:translateX(16px);
background:linear-gradient(135deg,#38bdf8,#6366f1);
}
.theme-toggle-icon {
position:absolute;
font-size:0.8em;
color:#e5e7eb;
}
.theme-toggle-icon.sun { left:6px; }
.theme-toggle-icon.moon { right:6px; }
body.theme-light .theme-toggle-icon.sun { color:#f59e0b; }
body.theme-light .theme-toggle-icon.moon { color:#9ca3af; }
.content {
padding: 16px 18px 20px;
}
.dashboard {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
gap: 12px;
margin-bottom: 18px;
}
.dashboard-card {
position: relative;
background: radial-gradient(circle at top left, rgba(30,64,175,0.35), rgba(15,23,42,0.96));
border-radius: 18px;
border: 1px solid rgba(129,140,248,0.55);
padding: 10px 12px;
text-align: center;
box-shadow: 0 18px 40px rgba(15,23,42,0.9);
backdrop-filter: blur(18px);
overflow:hidden;
transition:background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
}
body.theme-light .dashboard-card {
background: radial-gradient(circle at top left, rgba(191,219,254,0.9), rgba(226,232,240,0.96));
border-color: rgba(129,140,248,0.7);
box-shadow: 0 14px 30px rgba(148,163,184,0.6);
}
.dashboard-card::before {
content:"";
position:absolute;
inset:-40%;
background:
radial-gradient(circle at top, rgba(248,250,252,0.16), transparent 55%);
opacity:0.6;
pointer-events:none;
}
.dashboard-card h3 {
color: #c7d2fe;
font-size: 0.75em;
margin-bottom: 6px;
text-transform: uppercase;
font-weight: 600;
letter-spacing: .14em;
position:relative;
z-index:1;
}
body.theme-light .dashboard-card h3 {
color:#4f46e5;
}
.dashboard-card .value {
font-size: 1.6em;
font-weight: 700;
color: #f9fafb;
position:relative;
z-index:1;
}
body.theme-light .dashboard-card .value {
color:#111827;
}
.dashboard-card .label {
font-size: 0.7em;
color: #9ca3af;
margin-top: 3px;
position:relative;
z-index:1;
}
body.theme-light .dashboard-card .label {
color:#6b7280;
}
.dashboard-card select {
width: 100%;
padding: 6px;
border-radius: 999px;
border: 1px solid rgba(129,140,248,0.7);
background: rgba(15,23,42,0.9);
color: #e5e7eb;
font-size: 1.1em;
font-weight: 600;
text-align: center;
margin-top: 4px;
outline:none;
box-shadow: 0 10px 25px rgba(15,23,42,0.8);
}
body.theme-light .dashboard-card select {
background:rgba(248,250,252,0.95);
color:#111827;
box-shadow:0 8px 20px rgba(148,163,184,0.5);
}
.volume-fait-section {
background: radial-gradient(circle at top, rgba(22,163,74,0.18), rgba(15,23,42,0.96));
padding: 14px 14px 16px;
border-radius: 18px;
border: 1px solid rgba(74,222,128,0.45);
margin-bottom: 18px;
box-shadow: 0 18px 40px rgba(15,23,42,0.9);
backdrop-filter: blur(18px);
transition:background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
}
body.theme-light .volume-fait-section {
background: radial-gradient(circle at top, rgba(187,247,208,0.9), rgba(240,253,250,0.96));
border-color: rgba(34,197,94,0.7);
box-shadow:0 14px 30px rgba(74,222,128,0.4);
}
.volume-fait-section h3 {
color: #bbf7d0;
margin-bottom: 10px;
font-size: 0.95em;
letter-spacing:.12em;
text-transform:uppercase;
}
body.theme-light .volume-fait-section h3 {
color:#15803d;
}
.volume-fait-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
gap: 10px;
}
.volume-fait-card {
background: var(--card-dark);
padding: 10px;
border-radius: 12px;
border: 1px solid rgba(74,222,128,0.45);
box-shadow: 0 12px 30px rgba(15,23,42,0.9);
transition:background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
}
body.theme-light .volume-fait-card {
background: var(--card-light);
border-color: rgba(34,197,94,0.7);
box-shadow:0 10px 24px rgba(148,163,184,0.5);
}
.volume-fait-card label {
display: block;
font-weight: 600;
color: #e5e7eb;
margin-bottom: 3px;
font-size: 0.8em;
}
body.theme-light .volume-fait-card label {
color:#111827;
}
.volume-fait-card input {
width: 100%;
padding: 6px 8px;
border-radius: 999px;
border: 1px solid rgba(74,222,128,0.7);
background: rgba(15,23,42,0.95);
color: #f9fafb;
font-size: 0.9em;
font-weight: 600;
text-align: center;
outline:none;
}
body.theme-light .volume-fait-card input {
background:rgba(248,250,252,0.96);
color:#111827;
}
.section {
margin-bottom: 18px;
padding: 14px 14px 16px;
background: var(--card-dark);
border-radius: 18px;
border: 1px solid var(--border-dark);
box-shadow: 0 18px 40px rgba(15,23,42,0.9);
backdrop-filter: blur(18px);
transition:background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
}
body.theme-light .section {
background: var(--card-light);
border-color: var(--border-light);
box-shadow:0 14px 30px rgba(148,163,184,0.5);
}
.section h2 {
color: #c7d2fe;
margin-bottom: 10px;
font-size: 1em;
text-transform:uppercase;
letter-spacing:.16em;
}
body.theme-light .section h2 {
color:#4f46e5;
}
.form-group {
margin-bottom: 10px;
}
.form-group label {
display: block;
margin-bottom: 4px;
font-weight: 600;
color: #e5e7eb;
font-size: 0.82em;
}
body.theme-light .form-group label {
color:#111827;
}
.form-group input,
.form-group select {
width: 100%;
padding: 8px 10px;
border-radius: 999px;
border: 1px solid rgba(148,163,184,0.7);
background: rgba(15,23,42,0.96);
color: #f9fafb;
font-size: 0.9em;
outline:none;
}
body.theme-light .form-group input,
body.theme-light .form-group select {
background:rgba(248,250,252,0.96);
color:#111827;
}
.form-group input:focus,
.form-group select:focus {
border-color: #38bdf8;
box-shadow: 0 0 0 1px rgba(56,189,248,0.5);
}
.wip-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
gap: 12px;
margin-top: 8px;
}
.wip-card {
background: var(--card-dark);
padding: 10px;
border-radius: 12px;
border: 1px solid rgba(129,140,248,0.6);
box-shadow: 0 14px 35px rgba(15,23,42,0.9);
transition:background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
}
body.theme-light .wip-card {
background: var(--card-light);
border-color: rgba(129,140,248,0.8);
box-shadow:0 10px 24px rgba(148,163,184,0.5);
}
.wip-card h3 {
color: #c7d2fe;
margin-bottom: 6px;
font-size: 0.9em;
}
body.theme-light .wip-card h3 {
color:#4f46e5;
}
.wip-card input {
width: 100%;
padding: 7px 9px;
border-radius: 999px;
border: 1px solid rgba(129,140,248,0.7);
background: rgba(15,23,42,0.96);
color:#f9fafb;
font-size:0.9em;
outline:none;
}
body.theme-light .wip-card input {
background:rgba(248,250,252,0.96);
color:#111827;
}
.checkbox-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
gap: 8px;
margin-top: 8px;
}
.checkbox-item {
display: flex;
align-items: center;
padding: 7px 9px;
background: var(--card-dark);
border-radius: 999px;
border: 1px solid rgba(148,163,184,0.6);
transition: all 0.2s;
}
body.theme-light .checkbox-item {
background:var(--card-light);
border-color:rgba(148,163,184,0.8);
}
.checkbox-item:hover {
border-color: #38bdf8;
transform: translateY(-1px);
box-shadow: 0 10px 24px rgba(15,23,42,0.9);
}
body.theme-light .checkbox-item:hover {
box-shadow:0 10px 24px rgba(148,163,184,0.6);
}
.checkbox-item input[type="checkbox"] {
width: 16px;
height: 16px;
margin-right: 8px;
cursor: pointer;
}
.checkbox-item label {
cursor: pointer;
margin: 0;
font-weight: 500;
font-size: 0.82em;
color: inherit;
}
.btn {
background: linear-gradient(135deg, #38bdf8 0%, #6366f1 100%);
color: white;
padding: 9px 26px;
border: none;
border-radius: 999px;
font-size: 0.9em;
font-weight: 600;
cursor: pointer;
transition: transform 0.18s, box-shadow 0.18s, filter 0.18s;
display: inline-block;
margin: 6px;
box-shadow: 0 14px 35px rgba(15,23,42,0.9);
}
.btn:hover {
transform: translateY(-2px);
box-shadow: 0 18px 45px rgba(15,23,42,0.95);
filter: brightness(1.05);
}
.btn-secondary {
background: linear-gradient(135deg, #f97373 0%, #fb7185 100%);
}
.btn-success {
background: linear-gradient(135deg, #22c55e 0%, #4ade80 100%);
}
.btn-swap {
background: linear-gradient(135deg, #22d3ee 0%, #6366f1 100%);
}
.btn-add {
background: linear-gradient(135deg, #4ade80 0%, #22c55e 100%);
}
.btn-delete {
background: linear-gradient(135deg, #ef4444 0%, #f97316 100%);
}
.btn-move {
background: linear-gradient(135deg, #facc15 0%, #f97316 100%);
}
.planning-container {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 16px;
margin-top: 12px;
}
.planning-section {
background: var(--card-dark);
border-radius: 18px;
padding: 12px 12px 14px;
box-shadow: 0 18px 40px rgba(15,23,42,0.9);
border: 1px solid var(--border-dark);
backdrop-filter: blur(18px);
transition:background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
}
body.theme-light .planning-section {
background: var(--card-light);
border-color: var(--border-light);
box-shadow:0 14px 30px rgba(148,163,184,0.5);
}
.planning-section h3 {
margin-bottom: 8px;
padding: 7px 9px;
border-radius: 999px;
color: white;
text-align: center;
font-size: 0.9em;
letter-spacing:.12em;
text-transform:uppercase;
}
.planning-section.direct h3 {
background: linear-gradient(135deg, #6366f1, #38bdf8);
}
.planning-section.indirect h3 {
background: linear-gradient(135deg, #facc15, #f97316);
color:#111827;
}
.planning-table {
width: 100%;
border-collapse: collapse;
margin-top: 8px;
font-size: 0.85em;
}
.planning-table th {
background: rgba(31,41,55,0.9);
color: #e5e7eb;
padding: 8px;
text-align: left;
font-weight: 600;
border: 1px solid rgba(55,65,81,0.9);
font-size: 0.8em;
}
body.theme-light .planning-table th {
background:rgba(226,232,240,0.96);
color:#111827;
border-color:rgba(148,163,184,0.8);
}
.planning-table td {
padding: 8px;
border: 1px solid rgba(55,65,81,0.9);
cursor: pointer;
}
body.theme-light .planning-table td {
border-color:rgba(148,163,184,0.8);
}
.planning-table tr:hover {
background: rgba(15,23,42,0.9);
}
body.theme-light .planning-table tr:hover {
background:rgba(241,245,249,0.96);
}
.process-vareo { background: #1e293b; }
.process-cs { background: #022c22; }
.process-finalize { background: #3b1f0a; }
.process-lamination { background: #111827; }
.process-ix { background: #022c22; }
.process-fixed { background: #3f1d1d; }
.process-qc { background: #3b2f0a; }
.process-ws { background: #1e293b; }
body.theme-light .process-vareo { background:#e0f2fe; }
body.theme-light .process-cs { background:#dcfce7; }
body.theme-light .process-finalize { background:#ffedd5; }
body.theme-light .process-lamination { background:#e5e7eb; }
body.theme-light .process-ix { background:#dcfce7; }
body.theme-light .process-fixed { background:#fee2e2; }
body.theme-light .process-qc { background:#fef3c7; }
body.theme-light .process-ws { background:#e0f2fe; }
.person-cell {
cursor: pointer;
padding: 2px 6px;
margin: 2px;
background: #22c55e;
color: white;
border-radius: 4px;
display: inline-block;
transition: all 0.2s;
