Vareo: ["Mariama", "Sophie", "Martine", "Irene", "Abdoul", "Hadari", "Sylla", "Shada", "Laurent", "Thibaud", "Kezza", "Ba", "Zola", "Elodie", "Koumba", "Saidou", "Oussmane", "Anouar", "Herve", "Diallo"],
CS: ["Mariama", "Sophie", "Martine", "Irene", "Abdoul", "Hadari", "Sylla", "Shada", "Laurent", "Thibaud", "Kezza", "Ba", "Zola", "Elodie", "Koumba", "Saidou", "Oussmane", "Ange", "Anouar", "Herve", "Diallo"],
Finalize: ["Mariama", "Sophie", "Martine", "Irene", "Abdoul", "Hadari", "Sylla", "Shada", "Laurent", "Thibaud", "Kezza", "Ba", "Zola", "Elodie", "Koumba", "Saidou", "Oussmane", "Ange", "Anouar", "Herve", "Diallo"],
Lamination: ["Mariama", "Sophie", "Martine", "Irene", "Abdoul", "Hadari", "Sylla", "Shada", "Laurent", "Thibaud", "Kezza", "Ba", "Zola", "Elodie", "Koumba", "Saidou", "Oussmane", "Ange", "Anouar", "Herve", "Diallo"],
WS: ["Hadari", "Sylla", "Thibaud", "Laurent", "Elodie", "Martine", "Zola", "Saidou", "Ba", "Oussmane", "Abdoul", "Irene", "Anouar", "Herve", "Diallo"]
};

const capacites = {CS: 220, Vareo: 350, Finalize: 345};
const DUREE_SHIFT = 7.33;
const DUREE_TRAVAIL_EFFECTIF = 7.0;
const periodes = [
{ nom: "Période 1", debut: "21h00", fin: "23h30" },
{ nom: "Période 2", debut: "00h10", fin: "02h40" },
{ nom: "Période 3", debut: "03h10", fin: "05h00" }
];

let currentPlanning = null;
let weekHistory = JSON.parse(localStorage.getItem('weekHistory')) || {};
let swapMode = false;
let swapModeType = null;
let swapSelection = { first: null, second: null };
let addMode = false;
let deleteMode = false;
let moveMode = false;
let moveSelection = null;
let addSelection = null;

// ✅ CORRECTION 2 : Récupération des noms depuis les paramètres URL (envoyés par skill_matrix_night.html)
function loadTeamFromURL() {
const params = new URLSearchParams(window.location.search);
const skills = ['CS', 'Vareo', 'Finalize', 'Lamination', 'WS', 'IX', 'IJ', 'PS', 'QC'];

skills.forEach(skill => {
const value = params.get(skill);
if (value) {
const names = value.split(',').map(n => n.trim()).filter(n => n !== '');
formations[skill] = [...new Set(names)];
}
});

const allNames = new Set();
Object.values(formations).forEach(liste => liste.forEach(nom => allNames.add(nom)));
equipe.length = 0;
equipe.push(...Array.from(allNames).sort());
}

function initTheme() {
