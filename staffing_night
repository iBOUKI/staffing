justify-content:space-between;
align-items:center;
margin-bottom:10px;
}
.modal-header h2 {
font-size:1em;
text-transform:uppercase;
letter-spacing:.16em;
color:#c7d2fe;
}
body.theme-light .modal-header h2 {
color:#4f46e5;
}
.modal-close {
