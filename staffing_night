
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Staffing Automatique v9.3 - Dashboard Optimisé</title>
    <style>
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
            radial-gradient(circle at top left, #1f2937 0, #020617 45%, #000 100%);
        color: #e5e7eb;
        padding: 18px;
        min-height: 100vh;
        font-size: 14px;
    }

    .container {
        max-width: 1600px;
        margin: 0 auto;
        background: radial-gradient(circle at top, rgba(15,23,42,0.96), rgba(15,23,42,0.92));
        border-radius: 22px;
        box-shadow: 0 24px 80px rgba(0,0,0,0.75);
        overflow: hidden;
        border: 1px solid rgba(148,163,184,0.35);
        backdrop-filter: blur(22px);
    }

    .header {
        background: linear-gradient(135deg, rgba(56,189,248,0.18), rgba(129,140,248,0.22));
        color: #f9fafb;
        padding: 20px 26px;
        border-bottom: 1px solid rgba(148,163,184,0.35);
        position: relative;
        overflow: hidden;
    }

    .header::before {
        content:"";
        position:absolute;
        inset:-40%;
        background:
            radial-gradient(circle at top left, rgba(96,165,250,0.35), transparent 55%),
            radial-gradient(circle at bottom right, rgba(129,140,248,0.25), transparent 55%);
        opacity:0.7;
        pointer-events:none;
    }

    .header h1 {
        font-size: 1.7em;
        margin-bottom: 4px;
        position:relative;
        z-index:1;
        letter-spacing: .06em;
    }

    .header p {
        font-size: 0.9em;
        opacity: 0.9;
        position:relative;
        z-index:1;
        color:#e5e7eb;
    }

    .content {
        padding: 18px 20px 22px;
    }

    /* DASHBOARD KPIs – LIQUID GLASS */
    .dashboard {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 12px;
        margin-bottom: 20px;
    }

    .dashboard-card {
        position: relative;
        background: radial-gradient(circle at top left, rgba(30,64,175,0.35), rgba(15,23,42,0.95));
        border-radius: 16px;
        border: 1px solid rgba(129,140,248,0.55);
        padding: 10px 12px;
        text-align: center;
        box-shadow: 0 18px 40px rgba(15,23,42,0.9);
        backdrop-filter: blur(18px);
        overflow:hidden;
    }

    .dashboard-card::before {
        content:"";
        position:absolute;
        inset:-40%;
        background:
            radial-gradient(circle at top, rgba(248,250,252,0.16), transparent 55%);
        opacity:0.6;
        pointer-events:none;
    }

    .dashboard-card h3 {
        color: #c7d2fe;
        font-size: 0.75em;
        margin-bottom: 6px;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: .14em;
        position:relative;
        z-index:1;
    }

    .dashboard-card .value {
        font-size: 1.6em;
        font-weight: 700;
        color: #f9fafb;
        position:relative;
        z-index:1;
    }

    .dashboard-card .label {
        font-size: 0.7em;
        color: #9ca3af;
        margin-top: 3px;
        position:relative;
        z-index:1;
    }

    .dashboard-card select {
        width: 100%;
        padding: 6px;
        border-radius: 999px;
        border: 1px solid rgba(129,140,248,0.7);
        background: rgba(15,23,42,0.9);
        color: #e5e7eb;
        font-size: 1.1em;
        font-weight: 600;
        text-align: center;
        margin-top: 4px;
        outline:none;
        box-shadow: 0 10px 25px rgba(15,23,42,0.8);
    }

    /* VOLUME FAIT – LIQUID GLASS */
    .volume-fait-section {
        background: radial-gradient(circle at top, rgba(22,163,74,0.18), rgba(15,23,42,0.96));
        padding: 14px 14px 16px;
        border-radius: 16px;
        border: 1px solid rgba(74,222,128,0.45);
        margin-bottom: 18px;
        box-shadow: 0 18px 40px rgba(15,23,42,0.9);
        backdrop-filter: blur(18px);
    }

    .volume-fait-section h3 {
        color: #bbf7d0;
        margin-bottom: 10px;
        font-size: 0.95em;
        letter-spacing:.12em;
        text-transform:uppercase;
    }

    .volume-fait-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 10px;
    }

    .volume-fait-card {
        background: rgba(15,23,42,0.96);
        padding: 10px;
        border-radius: 12px;
        border: 1px solid rgba(74,222,128,0.45);
        box-shadow: 0 12px 30px rgba(15,23,42,0.9);
    }

    .volume-fait-card label {
        display: block;
        font-weight: 600;
        color: #e5e7eb;
        margin-bottom: 3px;
        font-size: 0.8em;
    }

    .volume-fait-card input {
        width: 100%;
        padding: 6px 8px;
        border-radius: 999px;
        border: 1px solid rgba(74,222,128,0.7);
        background: rgba(15,23,42,0.95);
        color: #f9fafb;
        font-size: 0.9em;
        font-weight: 600;
        text-align: center;
        outline:none;
    }

    /* PRINTERS – LIQUID GLASS */
    .printers-section {
        background: radial-gradient(circle at top, rgba(234,179,8,0.18), rgba(15,23,42,0.96));
        padding: 14px 14px 16px;
        border-radius: 16px;
        border-left: 3px solid rgba(250,204,21,0.8);
        margin-bottom: 18px;
        box-shadow: 0 18px 40px rgba(15,23,42,0.9);
        backdrop-filter: blur(18px);
    }

    .printers-section h3 {
        color: #facc15;
        margin-bottom: 10px;
        font-size: 0.95em;
        letter-spacing:.12em;
        text-transform:uppercase;
    }

    .printers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 14px;
    }

    .printer-card {
        background: rgba(15,23,42,0.96);
        padding: 12px 12px 10px;
        border-radius: 14px;
        border: 1px solid rgba(250,204,21,0.6);
        box-shadow: 0 14px 35px rgba(15,23,42,0.9);
    }

    .printer-card h4 {
        color: #fde68a;
        margin-bottom: 8px;
        font-size: 0.9em;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .printer-card h4 .icon {
        font-size: 1.1em;
    }

    .printer-status {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 6px;
        padding: 6px 7px;
        border-radius: 999px;
        font-size: 0.8em;
        background: rgba(15,23,42,0.95);
        border: 1px solid rgba(148,163,184,0.6);
        color:#e5e7eb;
    }

    .printer-status label {
        font-weight: 600;
        color: #e5e7eb;
        flex: 1;
        font-size: 0.78em;
    }

    .printer-status input[type="radio"] {
        width: 16px;
        height: 16px;
        cursor: pointer;
    }

    .status-ok {
        background: rgba(22,163,74,0.16);
        border-left: 3px solid #22c55e;
    }
    .status-ko {
        background: rgba(220,38,38,0.16);
        border-left: 3px solid #ef4444;
    }
    .status-maintenance {
        background: rgba(234,179,8,0.16);
        border-left: 3px solid #eab308;
    }
    .status-decommissioned {
        background: rgba(148,163,184,0.16);
        border-left: 3px solid #6b7280;
    }

    .printer-production {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 7px 9px;
        background: rgba(15,23,42,0.96);
        border-radius: 999px;
        margin-top: 6px;
        border: 1px solid rgba(250,204,21,0.5);
    }

    .printer-production .label {
        font-weight: 600;
        color: #e5e7eb;
        font-size: 0.78em;
    }

    .printer-production .value {
        font-size: 1em;
        font-weight: 700;
        color: #facc15;
    }

    .printer-input {
        width: 100%;
        padding: 7px 9px;
        border-radius: 999px;
        border: 1px solid rgba(250,204,21,0.7);
        background: rgba(15,23,42,0.96);
        color: #f9fafb;
        font-size: 0.9em;
        font-weight: 600;
        text-align: center;
        margin-top: 6px;
        outline:none;
    }

    /* SECTIONS – LIQUID GLASS */
    .section {
        margin-bottom: 18px;
        padding: 14px 14px 16px;
        background: rgba(15,23,42,0.96);
        border-radius: 16px;
        border: 1px solid rgba(148,163,184,0.45);
        box-shadow: 0 18px 40px rgba(15,23,42,0.9);
        backdrop-filter: blur(18px);
    }

    .section h2 {
        color: #c7d2fe;
        margin-bottom: 10px;
        font-size: 1em;
        text-transform:uppercase;
        letter-spacing:.16em;
    }

    .form-group {
        margin-bottom: 10px;
    }

    .form-group label {
        display: block;
        margin-bottom: 4px;
        font-weight: 600;
        color: #e5e7eb;
        font-size: 0.82em;
    }

    .form-group input,
    .form-group select {
        width: 100%;
        padding: 8px 10px;
        border-radius: 999px;
        border: 1px solid rgba(148,163,184,0.7);
        background: rgba(15,23,42,0.96);
        color: #f9fafb;
        font-size: 0.9em;
        outline:none;
    }

    .form-group input:focus,
    .form-group select:focus {
        border-color: #38bdf8;
        box-shadow: 0 0 0 1px rgba(56,189,248,0.5);
    }

    /* WIP GRID */
    .wip-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
        margin-top: 8px;
    }

    .wip-card {
        background: rgba(15,23,42,0.96);
        padding: 10px;
        border-radius: 12px;
        border: 1px solid rgba(129,140,248,0.6);
        box-shadow: 0 14px 35px rgba(15,23,42,0.9);
    }

    .wip-card h3 {
        color: #c7d2fe;
        margin-bottom: 6px;
        font-size: 0.9em;
    }

    .wip-card input {
        width: 100%;
        padding: 7px 9px;
        border-radius: 999px;
        border: 1px solid rgba(129,140,248,0.7);
        background: rgba(15,23,42,0.96);
        color:#f9fafb;
        font-size:0.9em;
        outline:none;
    }

    /* ABSENCES */
    .checkbox-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 8px;
        margin-top: 8px;
    }

    .checkbox-item {
        display: flex;
        align-items: center;
        padding: 7px 9px;
        background: rgba(15,23,42,0.96);
        border-radius: 999px;
        border: 1px solid rgba(148,163,184,0.6);
        transition: all 0.2s;
    }

    .checkbox-item:hover {
        border-color: #38bdf8;
        transform: translateY(-1px);
        box-shadow: 0 10px 24px rgba(15,23,42,0.9);
    }

    .checkbox-item input[type="checkbox"] {
        width: 16px;
        height: 16px;
        margin-right: 8px;
        cursor: pointer;
    }

    .checkbox-item label {
        cursor: pointer;
        margin: 0;
        font-weight: 500;
        font-size: 0.82em;
        color:#e5e7eb;
    }

    /* BUTTONS – LIQUID GLASS */
    .btn {
        background: linear-gradient(135deg, #38bdf8 0%, #6366f1 100%);
        color: white;
        padding: 9px 26px;
        border: none;
        border-radius: 999px;
        font-size: 0.9em;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.18s, box-shadow 0.18s, filter 0.18s;
        display: inline-block;
        margin: 6px;
        box-shadow: 0 14px 35px rgba(15,23,42,0.9);
    }

    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 18px 45px rgba(15,23,42,0.95);
        filter: brightness(1.05);
    }

    .btn-secondary {
        background: linear-gradient(135deg, #f97373 0%, #fb7185 100%);
    }

    .btn-success {
        background: linear-gradient(135deg, #22c55e 0%, #4ade80 100%);
    }

    .btn-move {
        background: linear-gradient(135deg, #f97316 0%, #facc15 100%);
    }

    .btn-swap {
        background: linear-gradient(135deg, #22d3ee 0%, #6366f1 100%);
    }

    .btn-add {
        background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    }

    .btn-delete {
        background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
    }

    /* PLANNING TABLES */
    .planning-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-top: 12px;
    }

    .planning-section {
        background: rgba(15,23,42,0.96);
        border-radius: 16px;
        padding: 12px 12px 14px;
        box-shadow: 0 18px 40px rgba(15,23,42,0.9);
        border: 1px solid rgba(148,163,184,0.55);
        backdrop-filter: blur(18px);
    }

    .planning-section h3 {
        margin-bottom: 8px;
        padding: 7px 9px;
        border-radius: 999px;
        color: white;
        text-align: center;
        font-size: 0.9em;
        letter-spacing:.12em;
        text-transform:uppercase;
    }

    .planning-section.direct h3 {
        background: linear-gradient(135deg, #6366f1, #38bdf8);
    }

    .planning-section.indirect h3 {
        background: linear
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🌙 Staffing Automatique v9.3 - Dashboard Optimisé</h1>
            <p>21h00 - 5h00 | Format compact 1 écran | AAS "15/20 dispo vs abs" | Temps écoulé | Printers avec statuts</p>
        </div>

        <div class="content">
            <!-- Dashboard Compact - Optimisé v9.3 -->
            <div class="dashboard">
                <div class="dashboard-card">
                    <h3>📦 Plan à faire</h3>
                    <div class="value" id="dashPlanAFaire">0</div>
                    <div class="label">livres</div>
                </div>
                <div class="dashboard-card">
                    <h3>⚡ TPH</h3>
                    <select id="dashTPH">
                        <option value="65">65</option>
                        <option value="66">66</option>
                        <option value="67">67</option>
                        <option value="68">68</option>
                        <option value="69">69</option>
                        <option value="70">70</option>
                        <option value="71">71</option>
                        <option value="72">72</option>
                        <option value="73">73</option>
                        <option value="74">74</option>
                        <option value="75" selected>75</option>
                        <option value="76">76</option>
                        <option value="77">77</option>
                        <option value="78">78</option>
                        <option value="79">79</option>
                        <option value="80">80</option>
                    </select>
                    <div class="label">Tasks/Hour</div>
                </div>
                <div class="dashboard-card">
                    <h3>📊 AAS</h3>
                    <div class="value" id="dashAAS">21/21</div>
                    <div class="label">dispo vs abs</div>
                </div>
                <div class="dashboard-card">
                    <h3>🔄 WIP Total</h3>
                    <div class="value" id="dashWIP">0</div>
                    <div class="label">livres</div>
                </div>
                <div class="dashboard-card">
                    <h3>📋 Backlog</h3>
                    <div class="value" id="dashBacklog">0</div>
                    <div class="label">Prisma + WIP</div>
                </div>
                <div class="dashboard-card">
                    <h3>⏱️ Temps Écoulé</h3>
                    <div class="value" id="dashTempsEcoule">0:00</div>
                    <div class="label">depuis 21h00</div>
                </div>
                <div class="dashboard-card">
                    <h3>🎯 À Produire/h</h3>
                    <div class="value" id="dashProdH">0</div>
                    <div class="label">livres/h (base 7h)</div>
                </div>
                <div class="dashboard-card">
                    <h3>✅ Volume FAIT</h3>
                    <div class="value" id="dashVolumeFait">0</div>
                    <div class="label">livres</div>
                </div>
            </div>

            <!-- Volume FAIT - Restructuré v9.3 -->
            <div class="volume-fait-section">
                <h3>✅ Volume FAIT - Saisie Interactive</h3>
                <div class="volume-fait-grid">
                    <div class="volume-fait-card">
                        <label>Livres Finalisés :</label>
                        <input type="number" id="livresFinalises" value="0" min="0" placeholder="Ex: 500">
                    </div>
                    <div class="volume-fait-card">
                        <label>Livres Printed :</label>
                        <input type="number" id="livresPrinted" value="0" min="0" placeholder="Ex: 300">
                    </div>
                    <div class="volume-fait-card">
                        <label>Buffer Finalize :</label>
                        <input type="number" id="bufferFinalize" value="0" min="0" placeholder="Ex: 200">
                    </div>
                    <div class="volume-fait-card">
                        <label>Reste à imprimer :</label>
                        <input type="number" id="resteImprimer" value="0" min="0" placeholder="Ex: 1000" readonly style="background: #f0f0f0;">
                    </div>
                    <div class="volume-fait-card">
                        <label>Livres déjà imprimés :</label>
                        <input type="number" id="livresImprimes" value="0" min="0" placeholder="Ex: 2000" readonly style="background: #f0f0f0;">
                    </div>
                </div>
            </div>

            <!-- Printers Section - Avec statuts colorés v9.3 -->
            <div class="printers-section">
                <h3>🖨️ Gestion des Imprimantes - Statuts Colorés</h3>
                <div class="printers-grid">
                    <!-- INKJET (IJ) - 2 imprimantes -->
                    <div class="printer-card">
                        <h4><span class="icon">🖨️</span> INKJET (IJ)</h4>
                        <div class="printer-status status-ok">
                            <label>IJ 1 :</label>
                            <input type="radio" name="ij1" value="ok" checked> OK
                            <input type="radio" name="ij1" value="ko"> KO
                            <input type="radio" name="ij1" value="maintenance"> Maint.
                            <input type="radio" name="ij1" value="decommissioned"> Décom.
                        </div>
                        <div class="printer-status status-ok">
                            <label>IJ 2 :</label>
                            <input type="radio" name="ij2" value="ok" checked> OK
                            <input type="radio" name="ij2" value="ko"> KO
                            <input type="radio" name="ij2" value="maintenance"> Maint.
                            <input type="radio" name="ij2" value="decommissioned"> Décom.
                        </div>
                        <label style="display: block; margin-top: 8px; font-weight: 600; color: #333; font-size: 0.8em;">Production/h :</label>
                        <input type="number" class="printer-input" id="ijProduction" value="500" min="0" max="999" placeholder="Ex: 500">
                        <div class="printer-production">
                            <span class="label">Total/h :</span>
                            <span class="value" id="ijTotalH">1000</span>
                        </div>
                        <div class="printer-production">
                            <span class="label">Total shift :</span>
                            <span class="value" id="ijTotalShift">7330</span>
                        </div>
                    </div>

                    <!-- B&W - Jusqu'à 11 printers -->
                    <div class="printer-card">
                        <h4><span class="icon">⚫</span> B&W (11 printers)</h4>
                        <div id="bwPrintersContainer"></div>
                        <div class="printer-production">
                            <span class="label">Total/h :</span>
                            <span class="value" id="bwTotalH">0</span>
                        </div>
                        <div class="printer-production">
                            <span class="label">Total shift :</span>
                            <span class="value" id="bwTotalShift">0</span>
                        </div>
                    </div>

                    <!-- IX -->
                    <div class="printer-card">
                        <h4><span class="icon">🔵</span> IX</h4>
                        <div class="printer-status status-ok">
                            <label>IX 1 :</label>
                            <input type="radio" name="ix1" value="ok" checked> OK
                            <input type="radio" name="ix1" value="ko"> KO
                            <input type="radio" name="ix1" value="maintenance"> Maint.
                            <input type="radio" name="ix1" value="decommissioned"> Décom.
                        </div>
                        <div class="printer-status status-ok">
                            <label>IX 2 :</label>
                            <input type="radio" name="ix2" value="ok" checked> OK
                            <input type="radio" name="ix2" value="ko"> KO
                            <input type="radio" name="ix2" value="maintenance"> Maint.
                            <input type="radio" name="ix2" value="decommissioned"> Décom.
                        </div>
                        <div class="printer-production">
                            <span class="label">Total/h :</span>
                            <span class="value" id="ixTotalH">300</span>
                        </div>
                        <div class="printer-production">
                            <span class="label">Total shift :</span>
                            <span class="value" id="ixTotalShift">2199</span>
                        </div>
                    </div>

                    <!-- Total Impression -->
                    <div class="printer-card" style="border-color: #70AD47;">
                        <h4 style="color: #70AD47;"><span class="icon">📊</span> Total Impression</h4>
                        <div class="printer-production" style="background: #E6F4EA;">
                            <span class="label">Total/h :</span>
                            <span class="value" style="color: #70AD47;" id="totalImpressionH">0</span>
                        </div>
                        <div class="printer-production" style="background: #E6F4EA;">
                            <span class="label">Total shift :</span>
                            <span class="value" style="color: #70AD47;" id="totalImpressionShift">0</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="section">
                <h2>📅 Jour de la semaine</h2>
                <div class="form-group">
                    <label for="jourSemaine">Sélectionnez le jour :</label>
                    <select id="jourSemaine">
                        <option value="Lundi">Lundi</option>
                        <option value="Mardi">Mardi</option>
                        <option value="Mercredi">Mercredi</option>
                        <option value="Jeudi">Jeudi</option>
                        <option value="Vendredi">Vendredi</option>
                    </select>
                </div>
            </div>

            <div class="section">
                <h2>📋 Étape 1 : Gestion des Absences</h2>
                <p style="margin-bottom: 10px; color: #666; font-size: 0.85em;">Cochez les personnes absentes ce soir :</p>
                <div class="checkbox-grid" id="absenceGrid"></div>
            </div>

