<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Staffing Night – Liquid Glass</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{
            font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
            min-height:100vh;
            display:flex;
            justify-content:center;
            align-items:flex-start;
            padding:30px;
            background:radial-gradient(circle at top,#1e293b 0,#020617 55%,#000 100%);
            color:#e5e7eb;
        }
        .glass-shell{
            width:100%;
            max-width:1400px;
            border-radius:26px;
            padding:1px;
            background:linear-gradient(135deg,rgba(148,163,253,.9),rgba(45,212,191,.9));
            box-shadow:0 24px 80px rgba(15,23,42,.85);
        }
        .glass-inner{
            border-radius:24px;
            background:linear-gradient(145deg,rgba(15,23,42,.92),rgba(15,23,42,.75));
            backdrop-filter:blur(26px) saturate(160%);
            -webkit-backdrop-filter:blur(26px) saturate(160%);
            padding:26px 26px 30px;
        }
        .header{
            display:flex;
            justify-content:space-between;
            align-items:flex-start;
            gap:20px;
            margin-bottom:24px;
        }
        .header-main h1{
            font-size:1.9rem;
            font-weight:650;
            letter-spacing:.03em;
            background:linear-gradient(120deg,#e5e7eb,#a5b4fc,#22c55e);
            -webkit-background-clip:text;
            color:transparent;
        }
        .header-main p{
            margin-top:6px;
            font-size:.9rem;
            color:#9ca3af;
        }
        .pill{
            display:inline-flex;
            align-items:center;
            gap:8px;
            padding:6px 12px;
            border-radius:999px;
            background:linear-gradient(135deg,rgba(15,23,42,.9),rgba(30,64,175,.9));
            border:1px solid rgba(148,163,253,.5);
            font-size:.8rem;
            color:#e5e7eb;
        }
        .back-link{
            display:inline-flex;
            align-items:center;
            gap:6px;
            padding:6px 12px;
            border-radius:999px;
            border:1px solid rgba(148,163,253,.4);
            background:linear-gradient(135deg,rgba(15,23,42,.9),rgba(15,23,42,.7));
            color:#c7d2fe;
            text-decoration:none;
            font-size:.85rem;
            transition:.2s;
        }
        .back-link:hover{
            transform:translateY(-1px);
            box-shadow:0 10px 30px rgba(15,23,42,.8);
            border-color:#a5b4fc;
        }
        .grid-two{
            display:grid;
            grid-template-columns:1fr 1fr;
            gap:18px;
            margin-top:18px;
        }
        .card{
            border-radius:20px;
            padding:18px 18px 20px;
            background:radial-gradient(circle at top left,rgba(148,163,253,.18),transparent 55%),
                       radial-gradient(circle at bottom right,rgba(45,212,191,.16),transparent 55%),
                       rgba(15,23,42,.9);
            border:1px solid rgba(148,163,253,.45);
            box-shadow:0 18px 50px rgba(15,23,42,.9);
        }
        .card h3{
            font-size:1.05rem;
            font-weight:600;
            color:#e5e7eb;
            display:flex;
            align-items:center;
            gap:8px;
            margin-bottom:12px;
        }
        .form-grid{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
            gap:12px;
            margin-top:12px;
        }
        .form-group{
            display:flex;
            flex-direction:column;
            gap:6px;
        }
        .form-group label{
            font-size:.85rem;
            color:#9ca3af;
        }
        .form-group input,.form-group select{
            padding:9px 11px;
            border-radius:12px;
            border:1px solid rgba(148,163,253,.45);
            background:radial-gradient(circle at top left,rgba(148,163,253,.18),transparent 55%),
                       rgba(15,23,42,.96);
            color:#e5e7eb;
            font-size:.85rem;
            outline:none;
        }
        .form-group input:focus,.form-group select:focus{
            border-color:#a5b4fc;
            box-shadow:0 0 0 1px rgba(129,140,248,.7);
        }
        .absence-grid{
            display:grid;
            grid-template-columns:repeat(auto-fill,minmax(150px,1fr));
            gap:8px;
            margin-top:12px;
        }
        .absence-item{
            display:flex;
            align-items:center;
            gap:8px;
            padding:8px 10px;
            border-radius:12px;
            background:linear-gradient(145deg,rgba(15,23,42,.96),rgba(15,23,42,.85));
            border:1px solid rgba(148,163,253,.35);
            font-size:.8rem;
        }
        .absence-item input[type="checkbox"]{
            width:16px;
            height:16px;
            cursor:pointer;
        }
        .buttons{
            margin-top:22px;
            display:flex;
            flex-wrap:wrap;
            gap:10px;
            justify-content:flex-end;
        }
        .btn{
            border:none;
            border-radius:999px;
            padding:9px 18px;
            font-size:.85rem;
            font-weight:500;
            cursor:pointer;
            display:inline-flex;
            align-items:center;
            gap:7px;
            color:#0b1120;
            background:linear-gradient(135deg,#a5b4fc,#22c55e);
            box-shadow:0 14px 40px rgba(22,163,74,.55);
            transition:.18s;
        }
        .btn:hover{
            transform:translateY(-1px);
            box-shadow:0 18px 55px rgba(22,163,74,.7);
        }
        .btn-secondary{
            background:linear-gradient(135deg,#f97316,#fb7185);
            color:#0b1120;
            box-shadow:0 14px 40px rgba(248,113,113,.55);
        }
        .section-title{
            margin-top:22px;
            font-size:1rem;
            font-weight:600;
            color:#e5e7eb;
            display:flex;
            align-items:center;
            gap:8px;
        }
        .planning-table{
            width:100%;
            margin-top:14px;
            border-collapse:collapse;
            border-radius:16px;
            overflow:hidden;
        }
        .planning-table th{
            padding:10px 12px;
            background:linear-gradient(135deg,rgba(148,163,253,.3),rgba(45,212,191,.3));
            border:1px solid rgba(148,163,253,.45);
            font-size:.85rem;
            text-align:left;
        }
        .planning-table td{
            padding:9px 12px;
            background:linear-gradient(145deg,rgba(15,23,42,.96),rgba(15,23,42,.85));
            border:1px solid rgba(148,163,253,.35);
            font-size:.8rem;
        }
        .rotation-tag{
            display:inline-block;
            padding:2px 8px;
            border-radius:999px;
            font-size:.7rem;
            margin-left:6px;
        }
        .rotation-1{background:rgba(59,130,246,.3);border:1px solid rgba(59,130,246,.6);color:#93c5fd;}
        .rotation-2{background:rgba(251,146,60,.3);border:1px solid rgba(251,146,60,.6);color:#fdba74;}
        .rotation-3{background:rgba(168,85,247,.3);border:1px solid rgba(168,85,247,.6);color:#d8b4fe;}
        #results{display:none;}
        @media(max-width:900px){
            .grid-two{grid-template-columns:1fr}
            .header{flex-direction:column;align-items:flex-start}
        }
    </style>
</head>
<body>
<div class="glass-shell">
    <div class="glass-inner">
        <div class="header">
            <div class="header-main">
                <h1>🌙 Staffing Automatique – Night Shift</h1>
                <p>21h00 – 5h00 · 3 périodes · Génération automatique du planning</p>
            </div>
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px;">
                <a href="skill_matrix_night.html" class="back-link">← Retour Skill Matrix</a>
                <span class="pill">
                    <span style="width:8px;height:8px;border-radius:999px;background:#22c55e;"></span>
                    Mode staffing nuit
                </span>
            </div>
        </div>

        <div class="grid-two">
            <div class="card">
                <h3>📊 Paramètres de Production</h3>
                <div class="form-grid">
                    <div class="form-group">
                        <label for="jourSemaine">Jour de la semaine *</label>
                        <select id="jourSemaine">
                            <option value="">-- Choisir --</option>
                            <option value="Lundi">Lundi</option>
                            <option value="Mardi">Mardi</option>
                            <option value="Mercredi">Mercredi</option>
                            <option value="Jeudi">Jeudi</option>
                            <option value="Vendredi">Vendredi</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="planQuotidien">Plan quotidien (livres) *</label>
                        <input type="number" id="planQuotidien" placeholder="Ex: 5000">
                    </div>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label for="wipCS">WIP Cover Submission</label>
                        <input type="number" id="wipCS" value="0">
                    </div>
                    <div class="form-group">
                        <label for="wipVareo">WIP Vareo</label>
                        <input type="number" id="wipVareo" value="0">
                    </div>
                    <div class="form-group">
                        <label for="wipFinalize">WIP Finalize</label>
                        <input type="number" id="wipFinalize" value="0">
                    </div>
                    <div class="form-group">
                        <label for="backlogPrisma">Backlog Prisma</label>
                        <input type="number" id="backlogPrisma" value="0">
                    </div>
                </div>
            </div>

            <div class="card">
                <h3>👥 Gestion des Absences</h3>
                <p style="font-size:.85rem;color:#9ca3af;margin-bottom:8px;">Cochez les personnes absentes</p>
                <div class="absence-grid" id="absenceGrid"></div>
            </div>
        </div>

        <div class="buttons">
            <button class="btn" onclick="genererPlanning()">🚀 Générer le Planning</button>
            <button class="btn btn-secondary" onclick="savePlanning()">💾 Sauvegarder</button>
            <button class="btn btn-secondary" onclick="resetForm()">🔄 Réinitialiser</button>
        </div>

        <div id="results">
            <h3 class="section-title">📋 Planning Généré</h3>
            <div class="card">
                <h3>🔵 DIRECT - Production Principale</h3>
                <table class="planning-table" id="planningTableDirect"></table>
            </div>
            <div class="card" style="margin-top:18px;">
                <h3>🟡 INDIRECT - Support & Impression</h3>
                <table class="planning-table" id="planningTableIndirect"></table>
            </div>
        </div>
    </div>
</div>

<script>
const equipe = {};
const capacites = { CS: 220, Vareo: 350, Finalize: 345 };
const postesFixes = ['IX', 'IJ', 'PS', 'Lead'];
const postesRotation = ['CS', 'Vareo', 'Finalize', 'WS'];
let currentPlanning = null;
let weekHistory = {};
// Récupération des noms depuis les paramètres URL
function loadTeamFromURL() {
    const params = new URLSearchParams(window.location.search);
    const skills = ['CS', 'Vareo', 'Finalize', 'Lamination', 'WS', 'IX', 'IJ', 'PS', 'QC'];

    skills.forEach(skill => {
        const value = params.get(skill);
        if (value) {
            const names = value.split(',').map(n => n.trim()).filter(n => n !== '');
            equipe[skill] = names;
        }
    });
}

// Initialisation de la grille des absences
function initAbsenceGrid() {
    const grid = document.getElementById('absenceGrid');
    if (!grid) return;

    const allNames = new Set();
    Object.values(equipe).forEach(liste => liste.forEach(nom => allNames.add(nom)));

    const sortedNames = Array.from(allNames).sort();

    grid.innerHTML = '';
    sortedNames.forEach(nom => {
        const div = document.createElement('div');
        div.className = 'absence-item';
        div.innerHTML = `
            <input type="checkbox" id="absent_${nom}" value="${nom}">
            <label for="absent_${nom}" style="cursor:pointer;">${nom}</label>
        `;
        grid.appendChild(div);
    });
}

// Calcul des besoins par processus
function calculerBesoins(planQuotidien, wipCS, wipVareo, wipFinalize) {
    const heuresTravail = 7.33;
    const planCS = Math.round(planQuotidien * 0.15);

    const besoinCS = Math.max(1, Math.ceil((wipCS + planCS) / capacites.CS / heuresTravail));
    const besoinVareo = Math.max(1, Math.ceil((wipVareo + planQuotidien) / capacites.Vareo / heuresTravail));
    const besoinFinalize = Math.max(1, Math.ceil((wipFinalize + planQuotidien) / capacites.Finalize / heuresTravail));

    return {
        Lead: 1,
        IX: 1,
        IJ: 2,
        PS: 1,
        QC: 1,
        CS: besoinCS,
        Vareo: besoinVareo,
        Finalize: besoinFinalize,
        WS: 1
    };
}

// Affectation du personnel par période
function affecterPersonnel(besoins, periode, absents) {
    const affectations = {};
    const disponibles = {};
    const dejaAffectes = new Set();

    // Filtrer les personnes disponibles (non absentes)
    Object.keys(equipe).forEach(poste => {
        disponibles[poste] = equipe[poste].filter(nom => !absents.includes(nom));
    });

    // Lead (Issam) - fixe tout le shift
    affectations.Lead = ['Issam'];
    dejaAffectes.add('Issam');

    // IX - 1 opérateur fixe tout le shift
    const ixDispo = disponibles.IX ? disponibles.IX.filter(nom => !dejaAffectes.has(nom)) : [];
    if (ixDispo.length > 0) {
        affectations.IX = [ixDispo];
        dejaAffectes.add(ixDispo);
    } else {
        affectations.IX = [];
    }

    // IJ - 2 opérateurs fixes tout le shift
    const ijDispo = disponibles.IJ ? disponibles.IJ.filter(nom => !dejaAffectes.has(nom)) : [];
    affectations.IJ = ijDispo.slice(0, 2);
    affectations.IJ.forEach(nom => dejaAffectes.add(nom));

    // PS - 1 opérateur fixe tout le shift
    const psDispo = disponibles.PS ? disponibles.PS.filter(nom => !dejaAffectes.has(nom)) : [];
    if (psDispo.length > 0) {
        affectations.PS = [psDispo];
        dejaAffectes.add(psDispo);
    } else {
        affectations.PS = [];
    }

    // QC - uniquement en Période 1 (21h-23h30)
    if (periode === 1) {
        const qcDispo = disponibles.QC ? disponibles.QC.filter(nom => !dejaAffectes.has(nom)) : [];
        if (qcDispo.length > 0) {
            affectations.QC = [qcDispo];
        } else {
            affectations.QC = [];
        }
    } else {
        affectations.QC = [];
    }

    // Postes avec rotation (CS, Vareo, Finalize, WS)
    postesRotation.forEach(poste => {
        const besoin = besoins[poste] || 1;
        const offset = (periode - 1) * besoin;

        const personnes = disponibles[poste] ? disponibles[poste].filter(nom => !dejaAffectes.has(nom)) : [];

        affectations[poste] = [];
        for (let i = 0; i < besoin; i++) {
            const index = (offset + i) % personnes.length;
            if (personnes[index]) {
                affectations[poste].push(personnes[index]);
            }
        }
    });

    return affectations;
}

// Génération du planning
function genererPlanning() {
    const jour = document.getElementById('jourSemaine').value;
    const planQuotidien = parseInt(document.getElementById('planQuotidien').value);
    const wipCS = parseInt(document.getElementById('wipCS').value) || 0;
    const wipVareo = parseInt(document.getElementById('wipVareo').value) || 0;
    const wipFinalize = parseInt(document.getElementById('wipFinalize').value) || 0;
    const backlogPrisma = parseInt(document.getElementById('backlogPrisma').value) || 0;

    if (!jour || !planQuotidien || planQuotidien <= 0) {
        alert('⚠️ Veuillez sélectionner un jour et saisir un plan de production valide !');
        return;
    }

    // Récupérer les absents
    const absents = [];
    document.querySelectorAll('#absenceGrid input[type="checkbox"]:checked').forEach(cb => {
        absents.push(cb.value);
    });

    // Calculer les besoins
    const besoins = calculerBesoins(planQuotidien, wipCS, wipVareo, wipFinalize);

    // Générer le planning pour les 3 périodes
    const planning = {
        periode1: affecterPersonnel(besoins, 1, absents),
        periode2: affecterPersonnel(besoins, 2, absents),
        periode3: affecterPersonnel(besoins, 3, absents)
    };

    // Sauvegarder le planning actuel
    currentPlanning = {
        jour,
        date: new Date().toLocaleDateString('fr-FR'),
        planQuotidien,
        wipCS,
        wipVareo,
        wipFinalize,
        backlogPrisma,
        absents,
        besoins,
        planning
    };

    // Afficher les résultats
    afficherResultats(planning, besoins);
}

// Affichage des résultats
function afficherResultats(planning, besoins) {
    document.getElementById('results').style.display = 'block';

    // Tableau DIRECT
    const tableDirect = document.getElementById('planningTableDirect');
    let htmlDirect = `
        <thead>
            <tr>
                <th>Poste</th>
                <th>Besoin</th>
                <th>Période 1<br>(21h-23h30)</th>
                <th>Période 2<br>(00h10-2h40)</th>
                <th>Période 3<br>(3h10-5h00)</th>
            </tr>
        </thead>
        <tbody>
    `;

    const postesDirect = ['CS', 'Vareo', 'Finalize', 'WS'];
    postesDirect.forEach(poste => {
        const besoin = besoins[poste] || 1;
        const p1 = planning.periode1[poste] || [];
        const p2 = planning.periode2[poste] || [];
        const p3 = planning.periode3[poste] || [];

        htmlDirect += `
            <tr>
                <td><strong>${poste}</strong></td>
                <td>${besoin}</td>
                <td>${p1.join(', ') || '❌'}<span class="rotation-tag rotation-1">R1</span></td>
                <td>${p2.join(', ') || '❌'}<span class="rotation-tag rotation-2">R2</span></td>
                <td>${p3.join(', ') || '❌'}<span class="rotation-tag rotation-3">R3</span></td>
            </tr>
        `;
    });

    htmlDirect += '</tbody>';
    tableDirect.innerHTML = htmlDirect;

    // Tableau INDIRECT
    const tableIndirect = document.getElementById('planningTableIndirect');
    let htmlIndirect = `
        <thead>
            <tr>
                <th>Poste</th>
                <th>Besoin</th>
                <th>Période 1<br>(21h-23h30)</th>
                <th>Période 2<br>(00h10-2h40)</th>
                <th>Période 3<br>(3h10-5h00)</th>
            </tr>
        </thead>
        <tbody>
    `;

    const postesIndirect = ['Lead', 'IX', 'IJ', 'PS', 'QC'];
    postesIndirect.forEach(poste => {
        const besoin = besoins[poste] || 1;
        const p1 = planning.periode1[poste] || [];
        const p2 = planning.periode2[poste] || [];
        const p3 = planning.periode3[poste] || [];
        const isQC = poste === 'QC';

        htmlIndirect += `
            <tr>
                <td><strong>${poste}</strong></td>
                <td>${besoin}</td>
                <td>${p1.join(', ') || '❌'}</td>
                <td>${isQC ? '➡️ Réaffecté' : (p2.join(', ') || '❌')}</td>
                <td>${isQC ? '➡️ Réaffecté' : (p3.join(', ') || '❌')}</td>
            </tr>
        `;
    });

    htmlIndirect += '</tbody>';
    tableIndirect.innerHTML = htmlIndirect;

    // Scroll vers les résultats
    document.getElementById('results').scrollIntoView({ behavior: 'smooth' });
}

// Sauvegarde du planning
function savePlanning() {
    if (!currentPlanning) {
        alert('⚠️ Aucun planning à sauvegarder !');
        return;
    }

    weekHistory[currentPlanning.jour] = currentPlanning;
    localStorage.setItem('weekHistory_night', JSON.stringify(weekHistory));

    alert(`✅ Planning du ${currentPlanning.jour} sauvegardé !`);
}

// Réinitialisation du formulaire
function resetForm() {
    document.getElementById('jourSemaine').value = '';
    document.getElementById('planQuotidien').value = '';
    document.getElementById('wipCS').value = '0';
    document.getElementById('wipVareo').value = '0';
    document.getElementById('wipFinalize').value = '0';
    document.getElementById('backlogPrisma').value = '0';

    document.querySelectorAll('#absenceGrid input[type="checkbox"]').forEach(cb => {
        cb.checked = false;
    });

    document.getElementById('results').style.display = 'none';
    currentPlanning = null;
}

// Initialisation au chargement de la page
document.addEventListener('DOMContentLoaded', function() {
    loadTeamFromURL();
    initAbsenceGrid();

    // Charger l'historique depuis localStorage
    const saved = localStorage.getItem('weekHistory_night');
    if (saved) {
        try {
            weekHistory = JSON.parse(saved);
        } catch (e) {
            weekHistory = {};
        }
    }
});
</script>
</body>
</html>

