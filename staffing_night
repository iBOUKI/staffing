}

function updateTempsEcoule() {
const now = new Date();
const shiftStart = new Date();
shiftStart.setHours(21, 0, 0, 0);
if (now.getHours() < 21) shiftStart.setDate(shiftStart.getDate() - 1);
const diff = now - shiftStart;
const hours = Math.floor(diff / (1000 * 60 * 60));
const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
document.getElementById('dashTempsEcoule').textContent = `${hours}:${minutes.toString().padStart(2, '0')}`;
}

function updateVolumeFait() {
const livresFinalises = parseInt(document.getElementById('livresFinalises').value) || 0;
const livresPrinted = parseInt(document.getElementById('livresPrinted').value) || 0;
const bufferFinalize = parseInt(document.getElementById('bufferFinalize').value) || 0;
const volumeFait = livresFinalises + livresPrinted + bufferFinalize;
document.getElementById('dashVolumeFait').textContent = volumeFait;
const livresImprimes = volumeFait;
document.getElementById('livresImprimes').value = livresImprimes;
const planQuotidien = parseInt(document.getElementById('planQuotidien').value) || 0;
const resteImprimer = Math.max(0, planQuotidien - livresImprimes);
document.getElementById('resteImprimer').value = resteImprimer;
}

function calculerStaffingTotal(wipCS, wipVareo, wipFinalize, backlog, plan) {
const staffing = {};
const details = {};
const planCS = plan * 0.15;
const totalCS = wipCS + backlog + planCS;
const besoinCS = totalCS / (capacites.CS * DUREE_SHIFT);
if (wipCS < 400) {
staffing.CS = 1;
} else {
staffing.CS = Math.min(2, Math.max(1, Math.ceil(besoinCS)));
}
details.CS = {wip: Math.round(totalCS), besoin: besoinCS.toFixed(2), note: wipCS < 400 ? '1 pers (WIP < 400)' : 'Max 2 pers', logins: staffing.CS};
const totalVareo = wipVareo + plan;
const besoinVareo = totalVareo / (capacites.Vareo * DUREE_SHIFT);
staffing.Vareo = Math.min(5, Math.max(1, Math.ceil(besoinVareo)));
details.Vareo = {wip: totalVareo, besoin: besoinVareo.toFixed(2), logins: staffing.Vareo};
const totalFinalize = wipFinalize + plan;
const besoinFinalize = totalFinalize / (capacites.Finalize * DUREE_SHIFT);
staffing.Finalize = Math.min(5, Math.max(2, Math.ceil(besoinFinalize)));
details.Finalize = {wip: totalFinalize, besoin: besoinFinalize.toFixed(2), note: 'Min 2 pers', logins: staffing.Finalize};
staffing.Lamination = 1;
staffing.WS = 1;
staffing.IX = 1;
staffing.IJ = 2;
staffing.PS = 1;
staffing.QC = 1;
return { staffing, details };
}

function assignerPostesFixes(absents) {
const disponibles = equipe.filter(p => !absents.includes(p));
const utilises = new Set();
const assignments = {};
assignments.IJ = formations.IJ.filter(p => disponibles.includes(p)).slice(0, 2);
assignments.IJ.forEach(p => utilises.add(p));
assignments.IX = formations.IX.filter(p => disponibles.includes(p) && !utilises.has(p)).slice(0, 1);
assignments.IX.forEach(p => utilises.add(p));
assignments.PS = formations.PS.filter(p => disponibles.includes(p) && !utilises.has(p)).slice(0, 1);
assignments.PS.forEach(p => utilises.add(p));
assignments.QC = formations.QC.filter(p => disponibles.includes(p) && !utilises.has(p)).slice(0, 1);
return { assignments, utilises };
}

function assignerPostesRotation(staffing, absents, utilisesFixe, periodeNum, assignmentsPrecedents, toutesLesAffectations) {
const disponibles = equipe.filter(p => !absents.includes(p));
const utilises = new Set([...utilisesFixe]);
const assignments = {};
if (periodeNum === 1) {
if (assignmentsPrecedents && assignmentsPrecedents.QC) {
assignmentsPrecedents.QC.forEach(p => utilises.add(p));
}
}
const personnesQCLibres = periodeNum > 1 && assignmentsPrecedents ? assignmentsPrecedents.QC : [];
const processesRotation = ['WS', 'Lamination', 'CS', 'Vareo', 'Finalize'];
processesRotation.forEach(process => {
const besoin = staffing[process];
const dejaAffectes = new Set();
if (toutesLesAffectations) {
toutesLesAffectations.forEach(periode => {
if (periode.assignments[process]) {
periode.assignments[process].forEach(p => dejaAffectes.add(p));
}
});
}
let candidats = formations[process].filter(p =>
disponibles.includes(p) &&
!utilises.has(p) &&
!dejaAffectes.has(p)
);
if (personnesQCLibres.length > 0 && periodeNum > 1) {
const qcFormes = personnesQCLibres.filter(p =>
formations[process].includes(p) &&
!utilises.has(p) &&
!dejaAffectes.has(p)
);
candidats = [...qcFormes, ...candidats.filter(p => !qcFormes.includes(p))];
}
if (candidats.length < besoin) {
const tousFormes = formations[process].filter(p =>
disponibles.includes(p) &&
!utilises.has(p)
);
const candidatsAvecScore = tousFormes.map(p => {
let score = 0;
if (toutesLesAffectations) {
toutesLesAffectations.forEach(periode => {
if (periode.assignments[process] && periode.assignments[process].includes(p)) {
score++;
}
});
}
return { personne: p, score };
});
candidatsAvecScore.sort((a, b) => a.score - b.score);
const candidatsSupplementaires = candidatsAvecScore.map(c => c.personne).filter(p => !candidats.includes(p));
candidats = [...candidats, ...candidatsSupplementaires];
}
const uniqueCandidats = [...new Set(candidats)];
assignments[process] = uniqueCandidats.slice(0, besoin);
assignments[process].forEach(p => utilises.add(p));
});
return assignments;
}

function updateDashboard(plan, wipCS, wipVareo, wipFinalize, backlogPrisma, staffing) {
const totalWIP = wipCS + wipVareo + wipFinalize;
const backlogTotal = backlogPrisma + totalWIP;
const volumeFait = parseInt(document.getElementById('dashVolumeFait').textContent) || 0;
const planAFaire = Math.max(0, plan - volumeFait);
document.getElementById('dashPlanAFaire').textContent = planAFaire;
document.getElementById('dashWIP').textContent = totalWIP;
document.getElementById('dashBacklog').textContent = backlogTotal;
const prodH = Math.round(planAFaire / DUREE_TRAVAIL_EFFECTIF);
document.getElementById('dashProdH').textContent = prodH;
}

function generatePlanning() {
const planQuotidien = parseInt(document.getElementById('planQuotidien').value) || 0;
const backlogPrisma = parseInt(document.getElementById('backlogPrisma').value) || 0;
const wipCS = parseInt(document.getElementById('wipCS').value) || 0;
const wipVareo = parseInt(document.getElementById('wipVareo').value) || 0;
const wipFinalize = parseInt(document.getElementById('wipFinalize').value) || 0;
const jour = document.getElementById('jourSemaine').value;
if (planQuotidien === 0) {
alert('⚠️ Veuillez entrer le plan quotidien !');
return;
}
const absents = [];
equipe.forEach(personne => {
const checkbox = document.getElementById(`absent_${personne}`);
if (checkbox && checkbox.checked) absents.push(personne);
});
const { staffing: staffingTotal, details: calculDetails } = calculerStaffingTotal(wipCS, wipVareo, wipFinalize, backlogPrisma, planQuotidien);
const { assignments: assignmentsFixe, utilises: utilisesFixe } = assignerPostesFixes(absents);
const planningComplet = [];
let assignmentsPrecedents = { QC: assignmentsFixe.QC };
periodes.forEach((periode, index) => {
const assignments = {};
assignments.IJ = assignmentsFixe.IJ;
assignments.IX = assignmentsFixe.IX;
assignments.PS = assignmentsFixe.PS;
assignments.QC = index === 0 ? assignmentsFixe.QC : [];
const assignmentsRotation = assignerPostesRotation(staffingTotal, absents, utilisesFixe, index + 1, assignmentsPrecedents, planningComplet);
Object.assign(assignments, assignmentsRotation);
planningComplet.push({ periode, staffing: staffingTotal, assignments });
assignmentsPrecedents = assignments;
});
currentPlanning = {
jour,
date: new Date().toLocaleDateString('fr-FR'),
planQuotidien,
backlogPrisma,
wipCS,
wipVareo,
wipFinalize,
absents,
planning: planningComplet,
staffing: staffingTotal,
details: calculDetails
};
updateDashboard(planQuotidien, wipCS, wipVareo, wipFinalize, backlogPrisma, staffingTotal);
afficherResultats(planningComplet, absents, planQuotidien, wipCS, wipVareo, wipFinalize, backlogPrisma, staffingTotal, calculDetails);
}

// ✅ CORRECTION 3 : Afficher 1 seule personne pour IX, PS, QC
function afficherResultats(planning, absents, plan, wipCS, wipVareo, wipFinalize, backlog, staffingTotal, calculDetails) {
document.getElementById('results').style.display = 'block';
const tableDirect = document.getElementById('planningTableDirect');
let htmlDirect = '<thead><tr><th>Process</th><th>Logins</th>';
planning.forEach(p => htmlDirect += `<th>${p.periode.nom}<br>${p.periode.debut} - ${p.periode.fin}</th>`);
htmlDirect += '</tr></thead><tbody>';
const processesDirect = ['CS', 'Vareo', 'Finalize'];
processesDirect.forEach(process => {
const logins = calculDetails[process].logins;
htmlDirect += `<tr class="process-${process.toLowerCase()}"><td><strong>${process}</strong></td><td><strong>${logins} logins</strong></td>`;
planning.forEach((p, periodeIdx) => {
const personnes = p.assignments[process] || [];
const personnesHTML = personnes.map((pers, idx) =>
`<span class="login-badge">L${idx + 1}</span><span class="person-cell" onclick="onPersonClick('${pers}','${process}',${periodeIdx}, this)">${pers}</span>`
).join(' ');
htmlDirect += `<td onclick="selectCellFor
Add('${process}', ${periodeIdx})">${personnesHTML || '-'}</td>`;
});
htmlDirect += '</tr>';
});
htmlDirect += '</tbody>';
tableDirect.innerHTML = htmlDirect;

const tableIndirect = document.getElementById('planningTableIndirect');
let htmlIndirect = '<thead><tr><th>Task</th><th>Staffing</th>';
planning.forEach(p => htmlIndirect += `<th>${p.periode.nom}<br>${p.periode.debut} - ${p.periode.fin}</th>`);
htmlIndirect += '</tr></thead><tbody>';
const processesIndirect = ['Lamination', 'IX', 'IJ', 'PS', 'QC', 'WS'];
processesIndirect.forEach(process => {
let rowClass = '';
if (['IJ', 'IX', 'PS'].includes(process)) rowClass = 'class="process-fixed"';
else if (process === 'QC') rowClass = 'class="process-qc"';
else rowClass = 'class="process-' + process.toLowerCase() + '"';
htmlIndirect += `<tr ${rowClass}><td><strong>${process}</strong></td><td><strong>${staffingTotal[process]} pers</strong></td>`;
planning.forEach((p, periodeIdx) => {
const personnes = p.assignments[process] || [];
// ✅ CORRECTION : Pour IX, PS, QC : afficher SEULEMENT la première personne
const personnesHTML = (['IX', 'PS', 'QC'].includes(process) && personnes.length > 0)
? `<span class="person-cell" onclick="onPersonClick('${personnes}','${process}',${periodeIdx}, this)">${personnes}</span>`
: personnes.map(pers =>
`<span class="person-cell" onclick="onPersonClick('${pers}','${process}',${periodeIdx}, this)">${pers}</span>`
).join(', ');
htmlIndirect += `<td onclick="selectCellForAdd('${process}', ${periodeIdx})">${personnesHTML || '-'}</td>`;
});
htmlIndirect += '</tr>';
});
htmlIndirect += '</tbody>';
tableIndirect.innerHTML = htmlIndirect;
document.getElementById('results').scrollIntoView({ behavior: 'smooth' });
}

function activateAddMode() {
addMode = !addMode;
deleteMode = false;
moveMode = false;
swapMode = false;
swapModeType = null;
swapSelection = { first: null, second: null };
document.getElementById('swapMenu').classList.remove('active');
if (addMode) alert('➕ Mode Ajouter activé. Cliquez sur une cellule pour ajouter une personne.');
else alert('❌ Mode Ajouter désactivé.');
}

function activateDeleteMode() {
deleteMode = !deleteMode;
addMode = false;
moveMode = false;
swapMode = false;
swapModeType = null;
swapSelection = { first: null, second: null };
document.getElementById('swapMenu').classList.remove('active');
if (deleteMode) alert('🗑️ Mode Effacer activé. Cliquez sur une personne pour la supprimer.');
else alert('❌ Mode Effacer désactivé.');
}

function activateMoveMode() {
moveMode = !moveMode;
addMode = false;
deleteMode = false;
swapMode = false;
swapModeType = null;
swapSelection = { first: null, second: null };
document.getElementById('swapMenu').classList.remove('active');
if (moveMode) alert('➡️ Mode Déplacer activé. Cliquez sur une personne pour la déplacer.');
else alert('❌ Mode Déplacer désactivé.');
}

function toggleSwapMenu() {
const menu = document.getElementById('swapMenu');
const isActive = menu.classList.contains('active');
menu.classList.toggle('active', !isActive);
if (!isActive) {
addMode = false;
deleteMode = false;
moveMode = false;
swapMode = false;
swapModeType = null;
swapSelection = { first: null, second: null };
alert('🔄 Choisissez un mode de Swap dans le menu.');
} else {
swapMode = false;
swapModeType = null;
swapSelection = { first: null, second: null };
}
}

function setSwapMode(type) {
swapModeType = type;
swapMode = true;
swapSelection = { first: null, second: null };
document.getElementById('swapMenu').classList.remove('active');
let msg = '';
if (type === 'local') msg = 'Swap local : la cellule uniquement.';
else if (type === 'process') msg = 'Swap par process : toutes les périodes pour ce process.';
else if (type === 'global') msg = 'Swap global : tout le planning.';
alert(`🔄 Mode Swap activé (${msg})
Cliquez sur deux personnes.`);
}

function selectCellForAdd(process, periodeIdx) {
if (!addMode || !currentPlanning) return;
addSelection = { process, periodeIdx };
const disponibles = equipe.filter(p => !currentPlanning.absents.includes(p));
const select = document.getElementById('personToAdd');
select.innerHTML = '<option value="">-- Sélectionnez --</option>';
disponibles.forEach(p => {
select.innerHTML += `<option value="${p}">${p}</option>`;
});
document.getElementById('addInfo').textContent = `Ajouter une personne à ${process} (Période ${periodeIdx + 1})`;
document.getElementById('addModal').classList.add('active');
}

function closeAddModal() {
document.getElementById('addModal').classList.remove('active');
addSelection = null;
}

function executeAdd() {
if (!addSelection || !currentPlanning) return;
const personToAdd = document.getElementById('personToAdd').value;
if (!personToAdd) {
alert('⚠️ Veuillez sélectionner une personne !');
return;
}
const planning = currentPlanning.planning;
const targetAssignments = planning[addSelection.periodeIdx].assignments[addSelection.process];
if (!targetAssignments.includes(personToAdd)) {
targetAssignments.push(personToAdd);
alert(`✅ ${personToAdd} ajouté(e) à ${addSelection.process} (Période ${addSelection.periodeIdx + 1}) !`);
} else {
alert(`⚠️ ${personToAdd} est déjà dans ${addSelection.process} (Période ${addSelection.periodeIdx + 1}) !`);
}
closeAddModal();
afficherResultats(currentPlanning.planning, currentPlanning.absents, currentPlanning.planQuotidien, currentPlanning.wipCS, currentPlanning.wipVareo, currentPlanning.wipFinalize, currentPlanning.backlogPrisma, currentPlanning.staffing, currentPlanning.details);
addMode = false;
}

function onPersonClick(personne, process, periodeIdx, el) {
if (!currentPlanning) return;
if (deleteMode) {
const planning = currentPlanning.planning;
const assignments = planning[periodeIdx].assignments[process];
const idx = assignments.indexOf(personne);
if (idx !== -1) {
assignments.splice(idx, 1);
alert(`✅ ${personne} supprimé(e) de ${process} (Période ${periodeIdx + 1}) !`);
afficherResultats(currentPlanning.planning, currentPlanning.absents, currentPlanning.planQuotidien, currentPlanning.wipCS, currentPlanning.wipVareo, currentPlanning.wipFinalize, currentPlanning.backlogPrisma, currentPlanning.staffing, currentPlanning.details);
}
deleteMode = false;
} else if (moveMode) {
moveSelection = { personne, process, periodeIdx };
document.getElementById('moveInfo').textContent = `Déplacer ${personne} depuis ${process} (Période ${periodeIdx + 1})`;
document.getElementById('moveModal').classList.add('active');
} else if (swapMode && swapModeType) {
selectPersonForSwap(personne, process, periodeIdx, el);
}
}

function selectPersonForSwap(personne, process, periodeIdx, el) {
if (!swapSelection.first) {
swapSelection.first = { personne, process, periodeIdx };
el.classList.add('person-selected');
alert(`✅ Première personne sélectionnée : ${personne} (${process} - Période ${periodeIdx + 1})`);
} else if (!swapSelection.second) {
swapSelection.second = { personne, process, periodeIdx };
el.classList.add('person-selected');
const first = swapSelection.first;
const second = swapSelection.second;
if (!currentPlanning) return;
const planning = currentPlanning.planning;
if (swapModeType === 'local') {
const firstAssignments = planning[first.periodeIdx].assignments[first.process];
const secondAssignments = planning[second.periodeIdx].assignments[second.process];
const firstIdx = firstAssignments.indexOf(first.personne);
const secondIdx = secondAssignments.indexOf(second.personne);
if (firstIdx !== -1 && secondIdx !== -1) {
firstAssignments[firstIdx] = second.personne;
secondAssignments[secondIdx] = first.personne;
}
} else if (swapModeType === 'process') {
const processName = first.process;
planning.forEach((periode, idx) => {
const arr = periode.assignments[processName];
if (!arr) return;
const idx1 = arr.indexOf(first.personne);
const idx2 = arr.indexOf(second.personne);
if (idx1 !== -1 && idx2 !== -1) {
const tmp = arr[idx1];
arr[idx1] = arr[idx2];
arr[idx2] = tmp;
} else if (idx1 !== -1 && idx2 === -1) {
arr[idx1] = second.personne;
} else if (idx1 === -1 && idx2 !== -1) {
arr[idx2] = first.personne;
}
});
} else if (swapModeType === 'global') {
planning.forEach(periode => {
Object.keys(periode.assignments).forEach(proc => {
const arr = periode.assignments[proc];
const idx1 = arr.indexOf(first.personne);
const idx2 = arr.indexOf(second.personne);
if (idx1 !== -1 && idx2 !== -1) {
const tmp = arr[idx1];
arr[idx1] = arr[idx2];
arr[idx2] = tmp;
} else if (idx1 !== -1 && idx2 === -1) {
arr[idx1] = second.personne;
} else if (idx1 === -1 && idx2 !== -1) {
arr[idx2] = first.personne;
}
});
});
}
alert(`✅ Swap effectué (${swapModeType}) !
${first.personne} (${first.process} P${first.periodeIdx + 1}) ↔️ ${second.personne} (${second.process} P${second.periodeIdx + 1})`);
afficherResultats(currentPlanning.planning, currentPlanning.absents, currentPlanning.planQuotidien, currentPlanning.wipCS, currentPlanning.wipVareo, currentPlanning.wipFinalize, currentPlanning.backlogPrisma, currentPlanning.staffing, currentPlanning.details);
swapSelection = { first: null, second: null };
swapMode = false;
swapModeType = null;
}
}

function closeMoveModal() {
document.getElementById('moveModal').classList.remove('active');
moveSelection = null;
}

function executeMove() {
if (!moveSelection || !currentPlanning) return;
const targetProcess = document.getElementById('targetProcess').value;
const targetPeriode = parseInt(document.getElementById('targetPeriode').value);
if (!targetProcess) {
alert('⚠️ Veuillez sélectionner un poste de destination !');
return;
}
const planning = currentPlanning.planning;
const sourceAssignments = planning[moveSelection.periodeIdx].assignments[moveSelection.process];
const targetAssignments = planning[targetPeriode].assignments[targetProcess];
const sourceIdx = sourceAssignments.indexOf(moveSelection.personne);
if (sourceIdx !== -1) {
sourceAssignments.splice(sourceIdx, 1);
}
if (!targetAssignments.includes(moveSelection.personne)) {
targetAssignments.push(moveSelection.personne);
}
alert(`✅ ${moveSelection.personne} déplacé(e) de ${moveSelection.process} (P${moveSelection.periodeIdx + 1}) vers ${targetProcess} (P${targetPeriode + 1}) !`);
closeMoveModal();
afficherResultats(currentPlanning.planning, currentPlanning.absents, currentPlanning.planQuotidien, currentPlanning.wipCS, currentPlanning.wipVareo, currentPlanning.wipFinalize, currentPlanning.backlogPrisma, currentPlanning.staffing, currentPlanning.details);
moveMode = false;
}

function savePlanning() {
if (!currentPlanning) {
alert('⚠️ Aucun planning à sauvegarder !');
return;
}
weekHistory[currentPlanning.jour] = currentPlanning;
localStorage.setItem('weekHistory', JSON.stringify(weekHistory));
alert(`✅ Planning du ${currentPlanning.jour} sauvegardé !`);
loadHistory();
}

function loadHistory() {
const historyGrid = document.getElementById('historyGrid');
const jours = ['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi'];
if (Object.keys(weekHistory).length === 0) {
historyGrid.innerHTML = '<p style="font-size: 0.85em;">Aucun planning sauvegardé.</p>';
return;
}
historyGrid.innerHTML = '';
jours.forEach(jour => {
if (weekHistory[jour]) {
const planning = weekHistory[jour];
const div = document.createElement('div');
div.className = 'history-card';
div.onclick = () => loadPlanningFromHistory(jour);
div.innerHTML = `
<h3>${jour} - ${planning.date}</h3>
<p><strong>Plan :</strong> ${planning.planQuotidien} livres</p>
<p><strong>WIP :</strong> ${planning.wipCS + planning.wipVareo + planning.wipFinalize} livres</p>
<p style="margin-top: 8px; color: #c7d2fe; font-weight: 600; font-size: 0.85em;">Cliquez pour afficher en grand</p>
`;
historyGrid.appendChild(div);
}
});
}

function loadPlanningFromHistory(jour) {
const planning = weekHistory[jour];
if (!planning) return;
document.getElementById('jourSemaine').value = jour;
document.getElementById('planQuotidien').value = planning.planQuotidien;
document.getElementById('backlogPrisma').value = planning.backlogPrisma;
document.getElementById('wipCS').value = planning.wipCS;
document.getElementById('wipVareo').value = planning.wipVareo;
document.getElementById('wipFinalize').value = planning.wipFinalize;
equipe.forEach(personne => {
const checkbox = document.getElementById(`absent_${personne}`);
if (checkbox) checkbox.checked = planning.absents.includes(personne);
});
currentPlanning = planning;
updateDashboard(planning.planQuotidien, planning.wipCS, planning.wipVareo, planning.wipFinalize, planning.backlogPrisma, planning.staffing);
afficherResultats(planning.planning, planning.absents, planning.planQuotidien, planning.wipCS, planning.wipVareo, planning.wipFinalize, planning.backlogPrisma, planning.staffing, planning.details);
const modal = document.getElementById('planningModal');
const modalTitle = document.getElementById('modalTitle');
const modalContent = document.getElementById('modalPlanningContent');
modalTitle.textContent = `Planning ${jour} - ${planning.date}`;
modalContent.innerHTML = `
<div class="planning-container">
<div class="planning-section direct">
<h3>🔵 DIRECT - Production Principale</h3>
<table class="planning-table">${document.getElementById('planningTableDirect').innerHTML}</table>
</div>
<div class="planning-section indirect">
<h3>🟡 INDIRECT - Support</h3>
<table class="planning-table">${document.getElementById('planningTableIndirect').innerHTML}</table>
</div>
</div>
`;
modal.classList.add('active');
}

function closePlanningModal() {
document.getElementById('planningModal').classList.remove('active');
}

function resetForm() {
document.getElementById('planQuotidien').value = '';
document.getElementById('backlogPrisma').value = '';
document.getElementById('wipCS').value = '0';
document.getElementById('wipVareo').value = '0';
document.getElementById('wipFinalize').value = '0';
document.getElementById('livresFinalises').value = '0';
